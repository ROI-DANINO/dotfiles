#!/usr/bin/env bash
# vr-desktop — start WiVRn, wait for Quest 3 to connect, then launch WayVR
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

info()    { echo -e "${CYAN}[vr]${RESET} $*"; }
success() { echo -e "${GREEN}[vr]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[vr]${RESET} $*"; }
error()   { echo -e "${RED}[vr]${RESET} $*" >&2; }

cleanup() {
  info "Shutting down..."
  kill "$WAYVR_PID" 2>/dev/null || true
  systemctl --user stop wivrn 2>/dev/null || true
  info "Done."
}

# ── 0. Ensure OpenXR runtime is registered ───────────────────────────────────
OPENXR_DIR="$HOME/.config/openxr/1"
RUNTIME_LINK="$OPENXR_DIR/active_runtime.json"
RUNTIME_SRC="/usr/share/openxr/1/openxr_wivrn.json"

mkdir -p "$OPENXR_DIR"
ln -sf "$RUNTIME_SRC" "$RUNTIME_LINK"

# ── 1. Start WiVRn ────────────────────────────────────────────────────────────
if systemctl --user is-active --quiet wivrn; then
  warn "WiVRn already running — restarting for a clean session"
  systemctl --user restart wivrn
else
  info "Starting WiVRn server..."
  systemctl --user start wivrn
fi

# Give the server a moment to initialise
sleep 1

if ! systemctl --user is-active --quiet wivrn; then
  error "WiVRn failed to start. Check: journalctl --user -u wivrn -n 30"
  exit 1
fi

success "WiVRn is running."

# ── 2. Wait for Quest 3 to connect ───────────────────────────────────────────
info "Put on your Quest 3 and open the WiVRn app, then connect to this PC..."
echo ""

TIMEOUT=120  # seconds to wait for headset
ELAPSED=0
CONNECTED=false

while [[ $ELAPSED -lt $TIMEOUT ]]; do
  # Poll WiVRn's DBus property HeadsetConnected
  if gdbus call --session \
      --dest io.github.wivrn.Server \
      --object-path /io/github/wivrn/Server \
      --method org.freedesktop.DBus.Properties.Get \
      io.github.wivrn.Server HeadsetConnected 2>/dev/null \
      | grep -q "true"; then
    CONNECTED=true
    break
  fi
  printf "\r${YELLOW}[vr]${RESET} Waiting for headset... (%ds/%ds)" "$ELAPSED" "$TIMEOUT"
  sleep 2
  ELAPSED=$((ELAPSED + 2))
done

echo ""

if [[ $CONNECTED == false ]]; then
  error "Timed out waiting for Quest 3 (${TIMEOUT}s). Is WiVRn installed on the headset?"
  error "Check: journalctl --user -u wivrn -f"
  systemctl --user stop wivrn
  exit 1
fi

success "Quest 3 connected!"

# ── 3. Launch WayVR ───────────────────────────────────────────────────────────
info "Launching WayVR virtual desktop..."
sleep 1

trap cleanup EXIT INT TERM

VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/intel_icd.x86_64.json wayvr --openxr --show &
WAYVR_PID=$!

success "WayVR launched (PID $WAYVR_PID). Your desktop should now appear in VR."
info  "Press Ctrl+C here to stop WayVR and WiVRn."

wait "$WAYVR_PID"
