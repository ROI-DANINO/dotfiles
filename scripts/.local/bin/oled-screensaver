#!/usr/bin/env bash
# OLED-safe screensaver: Pulse design ‚Äî cream clock + steel date + teal accent lines
# Black background = OLED pixels off. Content drifts via sin/cos to prevent burn-in.
# Lines drift at slight phase offset from clock for a parallax layer feel.
# Designed for Samsung SDC4154 eDP-1 (2880x1800 physical, 1440x900 logical @90Hz).

FONT="/home/roking/.local/share/fonts/JetBrainsMono/JetBrainsMonoNerdFont-Regular.ttf"
MPV_PID=""
CLEANED=0

cleanup() {
    [ "$CLEANED" -eq 1 ] && return
    CLEANED=1
    [ -n "$MPV_PID" ] && kill "$MPV_PID" 2>/dev/null
    pkill -USR1 waybar 2>/dev/null
}
trap cleanup EXIT TERM INT

pkill -USR1 waybar 2>/dev/null
sleep 0.15

FILTER="color=c=black:size=1440x900:rate=25"

# Top line 1 ‚Äî steel blue, slightly offset drift phase (parallax)
FILTER+=",drawtext=fontfile=${FONT}:text=‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ"
FILTER+=":fontcolor=0x8AAFC2@0.45:fontsize=14"
FILTER+=":x=(W-tw)/2+120*sin(t/13+0.4)"
FILTER+=":y=H/2-120+60*cos(t/17+0.25)"

# Top line 2 ‚Äî teal, same drift as clock
FILTER+=",drawtext=fontfile=${FONT}:text=‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ"
FILTER+=":fontcolor=0x567C8D@0.55:fontsize=14"
FILTER+=":x=(W-tw)/2+120*sin(t/13)"
FILTER+=":y=H/2-104+60*cos(t/17)"

# Clock ‚Äî cream, large
FILTER+=",drawtext=fontfile=${FONT}:text=%H\\\\:%M"
FILTER+=":expansion=strftime"
FILTER+=":fontcolor=0xF0E7D5@0.90:fontsize=180"
FILTER+=":x=(W-tw)/2+120*sin(t/13)"
FILTER+=":y=H/2-90+60*cos(t/17)"

# Date ‚Äî steel blue, below clock
FILTER+=",drawtext=fontfile=${FONT}:text=%A %-d %B"
FILTER+=":expansion=strftime"
FILTER+=":fontcolor=0x8AAFC2@0.65:fontsize=38"
FILTER+=":x=(W-tw)/2+120*sin(t/13)"
FILTER+=":y=H/2+105+60*cos(t/17)"

# Bottom line ‚Äî teal, slightly offset drift (parallax)
FILTER+=",drawtext=fontfile=${FONT}:text=‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ"
FILTER+=":fontcolor=0x567C8D@0.45:fontsize=14"
FILTER+=":x=(W-tw)/2+120*sin(t/13-0.4)"
FILTER+=":y=H/2+155+60*cos(t/17-0.25)"

mpv \
    --fullscreen \
    --no-osc \
    --loop=inf \
    --no-audio \
    --osd-level=0 \
    --stop-screensaver=no \
    --no-input-default-bindings \
    --title=oled-screensaver \
    "av://lavfi:${FILTER}" &

MPV_PID=$!
wait "$MPV_PID"
