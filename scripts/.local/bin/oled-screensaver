#!/usr/bin/env bash
# OLED-safe screensaver: moving clock on pure black background
# Black = OLED pixels off (saves power). Clock position oscillates to prevent burn-in.
# Designed for Samsung SDC4154 eDP-1 (2880x1800 physical, 1440x900 logical @90Hz).
#
# Triggered by swayidle; dismissed via swayidle resume (pkill -f oled-screensaver).

FONT="/home/roking/.local/share/fonts/JetBrainsMono/JetBrainsMonoNerdFont-Regular.ttf"
MPV_PID=""
CLEANED=0

cleanup() {
    [ "$CLEANED" -eq 1 ] && return
    CLEANED=1
    [ -n "$MPV_PID" ] && kill "$MPV_PID" 2>/dev/null
    pkill -USR1 waybar 2>/dev/null
}
trap cleanup EXIT TERM INT

# Hide waybar so mpv fullscreen covers the whole screen
pkill -USR1 waybar 2>/dev/null
sleep 0.15

# Moving clock: sin(t/13) and cos(t/17) give irrational-period oscillation
# so the clock position never exactly repeats within a reasonable timeframe.
# \\\\: in bash double-quoted → \\: to FFmpeg → literal : in text (not separator)
FILTER="color=c=black:size=1440x900:rate=1"
FILTER+=",drawtext=fontfile=${FONT}"
FILTER+=":text=%H\\\\:%M"
FILTER+=":expansion=strftime"
FILTER+=":fontcolor=0xF0E7D5@0.6"
FILTER+=":fontsize=180"
FILTER+=":x=(W-tw)/2+180*sin(t/13)"
FILTER+=":y=(H-th)/2+90*cos(t/17)"

mpv \
    --fullscreen \
    --loop=inf \
    --no-audio \
    --osd-level=0 \
    --stop-screensaver=no \
    --no-input-default-bindings \
    --title=oled-screensaver \
    "av://lavfi:${FILTER}" &

MPV_PID=$!
wait "$MPV_PID"
