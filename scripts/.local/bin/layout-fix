#!/usr/bin/env python3
import argparse
import fcntl
import json
import os
import shutil
import subprocess
import sys
import time
import glob


RELEASE_DEADLINE = 0.55       # seconds since launch before synthetic key events;
                              # a held Mod turns Ctrl+C/V into Super+Ctrl+C/V
PASTE_SETTLE_WAIT = 0.35      # after paste, before restoring the clipboard; runs
                              # after the user-visible work, so it costs no latency
CLIPBOARD_POLL_TIMEOUT = 0.5  # max wait for wl-copy to propagate
COPY_POLL_TIMEOUT = 0.6       # max wait for a simulated Ctrl+C to produce content
BACKSPACE_SETTLE = 0.05       # after terminal backspaces, before paste
LOCK_PATH = os.path.join(os.environ.get("XDG_RUNTIME_DIR") or "/tmp", "layout-fix.lock")
DEFAULT_TIMEOUT = 2.0     # bound for clipboard / niri / paste calls
BACKSPACE_TIMEOUT = 3.0   # bound for the bulk-backspace wtype call


US_TO_HEBREW = {
    "`": ";",
    "q": "/",
    "w": "'",
    "e": "ק",
    "r": "ר",
    "t": "א",
    "y": "ט",
    "u": "ו",
    "i": "ן",
    "o": "ם",
    "p": "פ",
    "[": "]",
    "]": "[",
    "a": "ש",
    "s": "ד",
    "d": "ג",
    "f": "כ",
    "g": "ע",
    "h": "י",
    "j": "ח",
    "k": "ל",
    "l": "ך",
    ";": "ף",
    "'": ",",
    "z": "ז",
    "x": "ס",
    "c": "ב",
    "v": "ה",
    "b": "נ",
    "n": "מ",
    "m": "צ",
    ",": "ת",
    ".": "ץ",
    "/": ".",
}

HEBREW_TO_US = {value: key for key, value in US_TO_HEBREW.items()}

# Characters unambiguously from the US layout
US_OUTPUT = set(US_TO_HEBREW.keys()) | {c.upper() for c in US_TO_HEBREW.keys() if c.isalpha()}
# Characters unambiguously from the Hebrew layout
HEB_OUTPUT = set(HEBREW_TO_US.keys())

# Characters that can be produced by both layouts natively (e.g. '.', ',', '/', ';', "'", '[', ']')
AMBIGUOUS = US_OUTPUT.intersection(HEB_OUTPUT)


def notify(title: str, body: str) -> None:
    if shutil.which("notify-send"):
        subprocess.run(["notify-send", title, body], check=False)


def is_us_only(char: str) -> bool:
    return char in US_OUTPUT and char not in AMBIGUOUS


def is_heb_only(char: str) -> bool:
    return char in HEB_OUTPUT and char not in AMBIGUOUS


def check_caps_lock() -> bool:
    """Reads the system LED status to determine if Caps Lock is currently ON."""
    try:
        for path in glob.glob("/sys/class/leds/*capslock/brightness"):
            with open(path, "r") as f:
                if f.read().strip() == "1":
                    return True
    except Exception:
        pass
    return False


def compute_states(text: str, caps_on: bool) -> list[int]:
    states: list[int] = []
    current_state = 0  # 1 = US->Heb, -1 = Heb->US, 2 = US->US

    # Forward pass to detect state for unambiguous characters
    for char in text:
        if not caps_on and char.isupper() and char in US_OUTPUT:
            current_state = 2
        elif is_us_only(char):
            current_state = 1
        elif is_heb_only(char):
            current_state = -1
        states.append(current_state)

    # Backward pass to fill initial ambiguous characters
    current_state = 0
    for i in range(len(text) - 1, -1, -1):
        if not caps_on and text[i].isupper() and text[i] in US_OUTPUT:
            current_state = 2
        elif is_us_only(text[i]):
            current_state = 1
        elif is_heb_only(text[i]):
            current_state = -1

        if states[i] == 0:
            states[i] = current_state

    # Default remaining fully ambiguous text (e.g. just commas) to US
    for i in range(len(states)):
        if states[i] == 0:
            states[i] = 1

    return states


def apply_states(text: str, states: list[int], caps_on: bool) -> str:
    result = []
    for i, char in enumerate(text):
        if states[i] == 2:
            # Typed in US, intended US (Shift was held)
            result.append(char)
        elif states[i] == 1:
            # Typed in US layout, intended Hebrew
            lower_char = char.lower()
            mapped = US_TO_HEBREW.get(lower_char, char)
            result.append(mapped)
        else:
            # Typed in Hebrew layout, intended US
            mapped = HEBREW_TO_US.get(char, char)
            # If they had caps lock on while typing Hebrew, uppercase the English output
            if caps_on and mapped.isalpha():
                mapped = mapped.upper()
            result.append(mapped)

    return "".join(result)


def dominant_language(states: list[int]) -> str | None:
    """Dominant intended language: 'heb', 'eng', or None on tie/empty."""
    heb = sum(1 for s in states if s == 1)
    eng = sum(1 for s in states if s in (-1, 2))
    if heb > eng:
        return "heb"
    if eng > heb:
        return "eng"
    return None


def convert_layout(text: str) -> str:
    caps_on = check_caps_lock()
    return apply_states(text, compute_states(text, caps_on), caps_on)


def target_language(text: str, caps_on: bool | None = None) -> str | None:
    """Dominant intended language of text: 'heb', 'eng', or None on tie/empty."""
    if caps_on is None:
        caps_on = check_caps_lock()
    return dominant_language(compute_states(text, caps_on))


def run_text(command: list[str], input_text: str | None = None,
             timeout: float = DEFAULT_TIMEOUT) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            command,
            input=input_text,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return subprocess.CompletedProcess(command, returncode=124, stdout="", stderr="timeout")


def run_quiet(command: list[str], timeout: float = DEFAULT_TIMEOUT) -> None:
    """Run a side-effecting command, ignoring failures and bounding by timeout."""
    try:
        subprocess.run(command, check=False, timeout=timeout)
    except subprocess.TimeoutExpired:
        pass


def require(command: str) -> bool:
    if shutil.which(command):
        return True
    notify("layout-fix", f"Missing dependency: {command}")
    print(f"layout-fix: missing dependency: {command}", file=sys.stderr)
    return False


def set_clipboard(text: str) -> None:
    run_text(["wl-copy", "--type", "text/plain"], text)


def wait_for_clipboard(expected: str, timeout: float) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if clipboard_text() == expected:
            return True
        time.sleep(0.02)
    return False


def save_clipboard() -> tuple[str, bool]:
    """Return (text, restorable). restorable=False => clipboard held non-text data."""
    result = run_text(["wl-paste", "--no-newline", "--type", "text"])
    if result.returncode == 0:
        return result.stdout, True
    if "nothing is copied" in result.stderr.lower():
        return "", True  # empty clipboard; restore by clearing
    return "", False     # non-text content (e.g. an image)


def restore_clipboard(saved: str, restorable: bool) -> None:
    if not restorable:
        notify("layout-fix", "Clipboard held non-text data; not restored")
        return
    if saved == "":
        run_quiet(["wl-copy", "--clear"])
    else:
        set_clipboard(saved)


def wait_for_release(start: float) -> None:
    """Sleep out the remainder of the Mod+G release window. Work already done
    since launch counts toward the deadline, so this costs only what is left."""
    time.sleep(max(0.0, start + RELEASE_DEADLINE - time.monotonic()))


def paste_combo(shift: bool) -> None:
    if shift:
        run_quiet(["wtype", "-M", "ctrl", "-M", "shift", "-k", "v", "-m", "shift", "-m", "ctrl"])
    else:
        run_quiet(["wtype", "-M", "ctrl", "-k", "v", "-m", "ctrl"])


def backspace(count: int) -> None:
    """Send `count` BackSpace presses in a single wtype invocation."""
    if count <= 0:
        return
    args = ["wtype"]
    for _ in range(count):
        args += ["-k", "BackSpace"]
    run_quiet(args, timeout=BACKSPACE_TIMEOUT)


def copy_combo(is_terminal: bool) -> None:
    if is_terminal:
        run_quiet(["wtype", "-M", "ctrl", "-M", "shift", "-k", "c", "-m", "shift", "-m", "ctrl"])
    else:
        run_quiet(["wtype", "-M", "ctrl", "-k", "c", "-m", "ctrl"])


def focused_is_kitty() -> bool:
    result = run_text(["niri", "msg", "--json", "focused-window"])
    if result.returncode != 0:
        return False
    try:
        return json.loads(result.stdout).get("app_id") == "kitty"
    except (json.JSONDecodeError, AttributeError):
        return False


def get_selection(is_terminal: bool, start: float) -> str:
    selected = primary_text()
    if selected:
        return selected

    # No primary selection: fall back to simulating Ctrl+C. Clear the clipboard
    # first (it is already saved) so a failed copy yields "no selection" instead
    # of silently handing us stale clipboard content, and wait out the Mod+G
    # release so the synthetic Ctrl+C is not swallowed as Super+Ctrl+C.
    run_quiet(["wl-copy", "--clear"])
    wait_for_release(start)
    copy_combo(is_terminal)

    deadline = time.monotonic() + COPY_POLL_TIMEOUT
    while time.monotonic() < deadline:
        selected = clipboard_text()
        if selected:
            return selected
        time.sleep(0.03)
    return ""


def pick_layout_index(layouts: dict, lang: str | None) -> int | None:
    """Index to switch to for `lang` given niri's keyboard-layouts JSON,
    or None when no switch is needed (unknown lang, already active, no match)."""
    name_needle = {"heb": "hebrew", "eng": "english"}.get(lang or "")
    if not name_needle:
        return None
    names = layouts.get("names") or []
    for index, name in enumerate(names):
        if name_needle in name.lower():
            return None if index == layouts.get("current_idx") else index
    return None


def switch_layout_for(lang: str | None) -> None:
    result = run_text(["niri", "msg", "--json", "keyboard-layouts"])
    if result.returncode != 0:
        return
    try:
        layouts = json.loads(result.stdout)
    except json.JSONDecodeError:
        return
    index = pick_layout_index(layouts, lang)
    if index is not None:
        run_quiet(["niri", "msg", "action", "switch-layout", str(index)])


def do_replace(fixed: str, selected: str, is_terminal: bool, start: float) -> None:
    set_clipboard(fixed)
    if not wait_for_clipboard(fixed, CLIPBOARD_POLL_TIMEOUT):
        notify("layout-fix", "Clipboard sync slow")

    # Wait for the user to physically release Mod+G; a held Mod key can
    # corrupt terminal bracketed-paste sequences.
    wait_for_release(start)

    if not is_terminal:
        # GUI apps: paste replaces the selection natively.
        paste_combo(shift=False)
        return

    # Terminals (kitty TUI apps): the OS does not replace the selection, so
    # delete the original by sending one BackSpace per selected character
    # (layout conversion is 1:1, so len(fixed) == len(selected)), then paste.
    backspace(len(selected))
    time.sleep(BACKSPACE_SETTLE)
    paste_combo(shift=True)


def clipboard_text() -> str:
    result = run_text(["wl-paste", "--no-newline", "--type", "text"])
    return result.stdout if result.returncode == 0 else ""


def primary_text() -> str:
    result = run_text(["wl-paste", "--primary", "--no-newline", "--type", "text"])
    return result.stdout if result.returncode == 0 else ""


def acquire_single_instance_lock():
    """Return an open fd holding an exclusive lock, or None if another run holds it.
    Keep the returned fd alive for the process lifetime; the lock releases on exit."""
    fd = open(LOCK_PATH, "w")
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        fd.close()
        return None
    return fd


def replace_selection() -> int:
    start = time.monotonic()

    lock_fd = acquire_single_instance_lock()
    if lock_fd is None:
        notify("layout-fix", "already running")
        return 0

    for command in ("wl-copy", "wl-paste", "wtype", "niri"):
        if not require(command):
            return 1

    is_terminal = focused_is_kitty()
    saved, restorable = save_clipboard()

    try:
        selected = get_selection(is_terminal, start)
        if not selected:
            notify("layout-fix", "No selected text found")
            return 1

        caps_on = check_caps_lock()
        states = compute_states(selected, caps_on)
        fixed = apply_states(selected, states, caps_on)
        if fixed == selected:
            notify("layout-fix", "Selection did not need layout conversion")
            return 0

        # Switch the layout before replacing the text: it does not depend on
        # the paste (wtype carries its own keymap), and sequencing it last is
        # what made the language flip feel laggy.
        switch_layout_for(dominant_language(states))

        do_replace(fixed, selected, is_terminal, start)
        time.sleep(PASTE_SETTLE_WAIT)
    finally:
        restore_clipboard(saved, restorable)

    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Fix Hebrew/English wrong-keyboard-layout text.")
    parser.add_argument("--convert", help="Convert text and print the result without touching the clipboard.")
    parser.add_argument("--detect-language", help="Print target language (heb/eng/none) without side effects.")
    args = parser.parse_args()

    if args.convert is not None:
        print(convert_layout(args.convert))
        return 0

    if args.detect_language is not None:
        print(target_language(args.detect_language) or "none")
        return 0

    return replace_selection()


if __name__ == "__main__":
    raise SystemExit(main())
