[global]
    ### Display ###
    monitor = 0
    follow = mouse

    ### Geometry ###
    width = 400
    height = (0, 800)
    origin = top-center
    offset = (0, 10)
    scale = 0
    notification_limit = 5

    ### Appearance ###
    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 0
    progress_bar_min_width = 380
    progress_bar_max_width = 380
    progress_bar_corner_radius = 2
    progress_bar_corners = all

    indicate_hidden = true
    transparency = 0
    separator_height = 1
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 1
    frame_color = "#567C8D"
    gap_size = 8
    separator_color = "#2F4156"

    sort = urgency_descending
    idle_threshold = 0

    ### Text ###
    font = Inter 12
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = false

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = "Papirus-Dark, Adwaita"
    icon_position = left
    min_icon_size = 48
    max_icon_size = 48
    icon_corner_radius = 10

    ### History ###
    sticky_history = yes
    history_length = 50

    ### Misc ###
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 12
    corners = all
    ignore_dbusclose = false
    force_xinerama = false

    ### Wayland ###
    layer = top

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1E3045"
    foreground = "#567C8D"
    frame_color = "#1E3045"
    highlight = "#567C8D"
    timeout = 4

[urgency_normal]
    background = "#F0E7D5"
    foreground = "#1E3045"
    frame_color = "#C8D9E6"
    highlight = "#567C8D"
    timeout = 6

[urgency_critical]
    background = "#C9856F"
    foreground = "#FFFFFF"
    frame_color = "#A85E4A"
    highlight = "#FFFFFF"
    timeout = 0
