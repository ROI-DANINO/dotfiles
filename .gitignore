# OS artifacts
.DS_Store

# Editor swap/backup files
*.swp
*.bak
*.save

# Machine-local config overrides (never commit these)
# Pattern: create <file>.local alongside any tracked config for per-machine overrides
# Note: *.local is scoped to root + named dirs only; scripts/.local/ is a stow package dir
.gitconfig.local
.zshrc.local
.shell_env.local
*.gitconfig.local

# Project environment files
.env
.env.*
!.env.template

# Runtime artifacts
__pycache__/
*.pyc
.pytest_cache/
.superpowers/
.remember/

# Claude Code local state (project commands are tracked; these are not)
.claude/settings.local.json
.claude/worktrees/
